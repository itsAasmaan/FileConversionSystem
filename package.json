  "bugs": {
    "url": "https://github.com/itsAasmaan/FileConversionSystem/issues"
  },
  "homepage": "https://github.com/itsAasmaan/FileConversionSystem#readme",
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
