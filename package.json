{
  "name": "fileconversionsystem",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade file conversion platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w @file-conversion-system/conversion-core",
    "start:core": "npm run start -w @file-conversion-system/conversion-core",
    "test": "npm run test --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itsAasmaan/FileConversionSystem.git"
  },
  "keywords": [],
